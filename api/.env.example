# ==============================================================================
# 🏆 WORLD CUP BACKEND API - ENVIRONMENT VARIABLES TEMPLATE (.env.example)
# ==============================================================================

NODE_ENV=development
SEED_DB=false # Set to 'true' to run database seeders on application startup

# 🌐 Server Settings
PORT=3000

# 🗄️ Database Configurations (PostgreSQL)
# Note: Use 'localhost' when running NestJS locally, or 'db' inside Docker Compose
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=wc_user
POSTGRES_PASSWORD=wc_password
POSTGRES_DB=wc_db

# 🔑 Authentication Settings (JWT Sessions)
JWT_SECRET=replace-with-a-secure-random-secret-key-in-production
FRONTEND_URL=http://localhost:4200

# 📧 SMTP Mail Settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-new-gmail-account@gmail.com
SMTP_PASS=your-16-character-app-password
SMTP_FROM="World Cup Predictor" <your-new-gmail-account@gmail.com>
